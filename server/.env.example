# Azure SQL Database connection (discrete DB_* vars — LFT format).
# Local dev uses the SQL Server 2022 container; UAT/prod uses Azure SQL.
DB_HOST=localhost
DB_PORT=1433
DB_NAME=ccl
# Auth mode: `sql` (DB_USER/DB_PASSWORD — local container) or `msi` (Azure AD
# managed identity, no password — UAT/prod).
DB_AUTH=sql
DB_USER=sa
DB_PASSWORD=Str0ng!Passw0rd2026
# For a *user-assigned* managed identity (DB_AUTH=msi) set its clientId here.
DB_MSI_CLIENT_ID=
# TLS: encrypt defaults ON (Azure SQL mandates it). Set DB_ENCRYPT=false only
# for a plaintext local engine.
DB_ENCRYPT=true
# trustServerCertificate: true ONLY for the local container's self-signed cert;
# MUST be false against Azure SQL.
DB_TRUST_SERVER_CERT=true
DB_POOL_MIN=2
DB_POOL_MAX=10

# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# Authentication
# DISABLE_LOGIN=true bypasses OAuth entirely (dev with mock user via X-User-Id header)
DISABLE_LOGIN=true

# OAuth2 / NBG Identity (required when DISABLE_LOGIN=false)
# OAUTH_ISSUER=https://myqa.nbg.gr/identity
# OAUTH_CLIENT_ID=
# OAUTH_CLIENT_SECRET=
# OAUTH_SCOPE=openid profile email rdarr-core-api-v1
# OAUTH_REDIRECT_URI=
