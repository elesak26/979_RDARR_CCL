{
  "name": "nbg-ccl",
  "private": true,
  "version": "1.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "install:all": "cd client && npm install && cd ../server && npm install",
    "dev": "concurrently -n client,server -c cyan,green \"cd client && npm run dev\" \"dotenv -e .env -- npx tsx --watch server/index.ts\"",
    "dev:client": "cd client && npm run dev",
    "dev:server": "dotenv -e .env -- npx tsx --watch server/index.ts",
    "build": "cd client && npm run build",
    "db:migrate": "cd server && npm run migrate",
    "db:seed": "cd server && npm run seed"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "concurrently": "^9.2.1",
    "dotenv-cli": "^11.0.0"
  }
}
