# Azure SQL Database connection (discrete DB_* vars — LFT format).
DB_HOST=HOST
DB_PORT=1433
DB_NAME=ccl
# Auth mode: `sql` (DB_USER/DB_PASSWORD) or `msi` (Azure AD managed identity, no
# password — set DB_MSI_CLIENT_ID too for a user-assigned identity).
DB_AUTH=sql
DB_USER=USER
DB_PASSWORD=PASSWORD
DB_MSI_CLIENT_ID=
# TLS: Azure SQL mandates encryption. Only set DB_TRUST_SERVER_CERT=true for a
# local self-signed container — never against real Azure SQL.
DB_ENCRYPT=true
DB_TRUST_SERVER_CERT=false

PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:4000
LOG_LEVEL=info

# Set to false for production OAuth2
DISABLE_LOGIN=true

VITE_API_URL=/api
